{
  "name": "@speconn/typespec-emitter-rust",
  "version": "0.0.19",
  "type": "module",
  "main": "dist/src/index.js",
  "typespec": {
    "emitter": true,
    "options": {
      "@speconn/typespec-emitter-rust": {
        "type": "object",
        "properties": {
          "emitter-output-dir": {
            "type": "string"
          },
          "target": {
            "type": "string",
            "enum": [
              "both",
              "client",
              "server"
            ],
            "default": "both",
            "description": "Generate 'client' only, 'server' only, or 'both' (default)"
          }
        },
        "required": [
          "emitter-output-dir"
        ]
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "watch": "tsc --watch"
  },
  "devDependencies": {
    "@typespec/compiler": "1.11.0",
    "@typespec/http": "1.11.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@speconn/typespec-emitter-core": "^0.0.6"
  },
  "publishConfig": {
    "access": "public",
    "registry": "http://10.199.64.20:3000/api/packages/speconn/npm/"
  }
}